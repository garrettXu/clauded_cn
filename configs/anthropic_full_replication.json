{
  "site_id": "anthropic_full",
  "target_url": "https://www.anthropic.com/",
  "out_dir": "/Users/elane/Documents/python/clauded_cn/output/anthropic_full",
  "force_refresh": false,
  "domain_policy": {
    "root_domain": "anthropic.com",
    "include_subdomains": true,
    "include": [
      "www.anthropic.com",
      "anthropic.com"
    ],
    "exclude": []
  },
  "crawl_policy": {
    "respect_robots": true,
    "max_pages_per_host": 10000,
    "max_depth": 50,
    "rate_limit_per_host": 0.2,
    "render_dynamic_pages": true,
    "dynamic_render_mode": "first_page",
    "require_browser_render": false,
    "dynamic_wait_ms": 600,
    "dynamic_network_idle_timeout_ms": 2500,
    "dynamic_scroll_rounds": 3,
    "dynamic_click_rounds": 1,
    "dynamic_click_limit": 20,
    "dynamic_timeout_seconds": 18,
    "download_videos": true,
    "download_documents": true,
    "max_asset_size_mb": 500,
    "max_assets_per_host": 0,
    "timeout_seconds": 20,
    "revalidate_completed_on_resume": false,
    "retry_failed_on_resume": false,
    "terminal_http_statuses": [
      404,
      410
    ],
    "max_attempts_per_page": 3,
    "worker_count": 10
  },
  "static_policy": {
    "runtime_database": false,
    "preserve_paths": true,
    "query_strategy": "record_and_map_when_needed",
    "external_link_policy": "keep_original"
  },
  "local_preview": {
    "port_start": 8700,
    "host_port_map": {
      "www.anthropic.com": 8700,
      "anthropic.com": 8701
    }
  },
  "deployment": {
    "generate_nginx": true,
    "base_root": "/srv/mirror/original",
    "scheme": "https",
    "target_base_domain": "clauded.cn",
    "inject_runtime_link_rewriter": true,
    "target_host_map": {
      "www.anthropic.com": "www.clauded.cn",
      "anthropic.com": "clauded.cn"
    }
  },
  "visual_policy": {
    "enabled": false,
    "sample_pages": 3,
    "diff_threshold": 0.02,
    "full_page": false,
    "wait_ms": 1200,
    "use_vision_model": false,
    "vision_api_url": "https://ark.cn-beijing.volces.com/api/v3",
    "vision_api_key_env": "VISION_API_KEY",
    "vision_model": "doubao-seed-1-6-flash-250828",
    "viewports": [
      {
        "name": "desktop",
        "width": 1365,
        "height": 900
      },
      {
        "name": "mobile",
        "width": 390,
        "height": 844
      }
    ]
  },
  "quality_policy": {
    "min_page_success_rate": 0.95,
    "min_resource_success_rate": 0.98,
    "max_unresolved_internal_links": 0,
    "max_residual_resources": 0,
    "require_visual_pass": false
  },
  "authorization_policy": {
    "require_ack": false,
    "authorized": true,
    "statement": "Anthropic mirror test authorized by the local operator for product validation."
  }
}
